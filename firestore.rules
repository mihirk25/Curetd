rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasParticipant(data) {
      return signedIn()
        && data.participants is list
        && request.auth.uid in data.participants;
    }

    function validConversationParticipants(data) {
      return data.participants is list
        && data.participants.size() == 2
        && data.participants[0] is string
        && data.participants[1] is string
        && data.participants[0] != data.participants[1];
    }

    function isConversationParticipant(conversationId) {
      return hasParticipant(
        get(/databases/$(database)/documents/conversations/$(conversationId)).data
      );
    }

    // Unique handles: public read; create/delete when the authenticated user matches { uid }.
    match /usernames/{uname} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid'])
        && request.auth.uid == request.resource.data.uid;
      allow update: if false;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.uid;
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    match /clips/{clipId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource != null
        && resource.data.userId == request.auth.uid;
    }

    match /clips/{clipId}/{sub=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /savedClips/{id} {
      allow read, write: if request.auth != null;
    }

    match /follows/{id} {
      allow read, write: if request.auth != null;
    }

    match /conversations/{id} {
      allow read: if hasParticipant(resource.data);
      allow create: if hasParticipant(request.resource.data)
        && validConversationParticipants(request.resource.data);
      allow update: if hasParticipant(resource.data)
        && validConversationParticipants(request.resource.data)
        && request.resource.data.participants == resource.data.participants;
      allow delete: if false;
    }

    match /conversations/{id}/messages/{mid} {
      allow read: if isConversationParticipant(id);
      allow create: if isConversationParticipant(id)
        && request.resource.data.keys().hasOnly(['senderId', 'text', 'createdAt', 'read'])
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.read == false;
      allow update: if isConversationParticipant(id)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
        && resource.data.read == false
        && request.resource.data.read == true;
      allow delete: if false;
    }
  }
}
