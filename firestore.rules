rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Unique handles: public read; create/delete when the authenticated user matches { uid }.
    match /usernames/{uname} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid'])
        && request.auth.uid == request.resource.data.uid;
      allow update: if false;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.uid;
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    match /clips/{clipId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource != null
        && resource.data.userId == request.auth.uid;
    }

    // Clip subcollections (likes, comments, …). Emoji reactions path removed from UI — block writes under reactions/*.
    match /clips/{clipId}/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && !document.matches("reactions/.*");
    }

    match /savedClips/{id} {
      allow read, write: if request.auth != null;
    }

    match /follows/{id} {
      allow read, write: if request.auth != null;
    }

    function signedIn() {
      return request.auth != null;
    }

    function isParticipant(data) {
      return signedIn()
        && data.participants is list
        && request.auth.uid in data.participants;
    }

    function isExistingParticipant(conversationId) {
      return signedIn()
        && exists(/databases/$(database)/documents/conversations/$(conversationId))
        && get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants is list
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    }

    function validConversationCreate() {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'participants',
          'isGroup',
          'groupName',
          'createdBy',
          'lastMessage',
          'lastMessageAt',
          'unreadBy'
        ])
        && request.resource.data.participants is list
        && request.resource.data.participants.size() >= 2
        && request.auth.uid in request.resource.data.participants
        && (
          !request.resource.data.keys().hasAny(['createdBy'])
          || request.resource.data.createdBy == request.auth.uid
        );
    }

    match /conversations/{id} {
      allow read: if isParticipant(resource.data);
      allow create: if validConversationCreate();
      allow update: if isParticipant(resource.data)
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'lastMessage',
          'lastMessageAt',
          'unreadBy'
        ]);
      allow delete: if false;
    }

    match /conversations/{id}/messages/{mid} {
      allow read: if isExistingParticipant(id);
      allow create: if isExistingParticipant(id)
        && request.resource.data.keys().hasOnly([
          'senderId',
          'text',
          'type',
          'clip',
          'youtubeUrl',
          'createdAt',
          'read'
        ])
        && request.resource.data.senderId == request.auth.uid
        && (
          !request.resource.data.keys().hasAny(['read'])
          || request.resource.data.read == false
        );
      allow update: if isExistingParticipant(id)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
        && request.resource.data.read == true;
      allow delete: if isExistingParticipant(id)
        && resource.data.senderId == request.auth.uid;
    }
  }
}
