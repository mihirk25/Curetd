rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedInAs(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function hasNoPrivateProfileFields() {
      return !request.resource.data.keys().hasAny(['firstName', 'lastName']);
    }

    // Unique handles: public read; create/delete when the authenticated user matches { uid }.
    match /usernames/{uname} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid'])
        && request.auth.uid == request.resource.data.uid;
      allow update: if false;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.uid;
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if isSignedInAs(userId) && hasNoPrivateProfileFields();
      allow delete: if false;
    }

    match /privateUsers/{userId} {
      allow read: if isSignedInAs(userId);
      allow create, update: if isSignedInAs(userId)
        && request.resource.data.keys().hasOnly(['firstName', 'lastName', 'updatedAt'])
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string;
      allow delete: if false;
    }

    match /clips/{clipId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource != null
        && resource.data.userId == request.auth.uid;
    }

    // Clip subcollections (likes, comments, …). Emoji reactions path removed from UI — block writes under reactions/*.
    match /clips/{clipId}/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && !document.matches("reactions/.*");
    }

    match /savedClips/{id} {
      allow read, write: if request.auth != null;
    }

    match /follows/{id} {
      allow read, write: if request.auth != null;
    }

    match /conversations/{id} {
      allow read, write: if request.auth != null;
    }

    match /conversations/{id}/messages/{mid} {
      allow read, write: if request.auth != null;
    }
  }
}
