rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function hasParticipant(data) {
      return signedIn()
        && data.participants is list
        && request.auth.uid in data.participants;
    }

    function isConversationParticipant(conversationId) {
      return signedIn()
        && exists(/databases/$(database)/documents/conversations/$(conversationId))
        && get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants is list
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    }

    // Unique handles: public read; create/delete when the authenticated user matches { uid }.
    match /usernames/{uname} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid'])
        && request.auth.uid == request.resource.data.uid;
      allow update: if false;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.uid;
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    match /clips/{clipId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource != null
        && resource.data.userId == request.auth.uid;
    }

    // Clip subcollections (likes, comments, …). Emoji reactions path removed from UI — block writes under reactions/*.
    match /clips/{clipId}/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && !document.matches("reactions/.*");
    }

    match /savedClips/{id} {
      allow read, write: if request.auth != null;
    }

    match /follows/{id} {
      allow read, write: if request.auth != null;
    }

    match /collections/{id} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;
      allow delete: if signedIn()
        && resource.data.userId == request.auth.uid;
    }

    match /conversations/{id} {
      allow create: if hasParticipant(request.resource.data);
      allow read, delete: if hasParticipant(resource.data);
      allow update: if hasParticipant(resource.data)
        && request.resource.data.participants == resource.data.participants;
    }

    match /conversations/{id}/messages/{mid} {
      allow read: if isConversationParticipant(id);
      allow create: if isConversationParticipant(id)
        && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isConversationParticipant(id);
    }
  }
}
