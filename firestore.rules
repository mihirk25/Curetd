rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsSavedClip() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function createsOwnSavedClip() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function isConversationParticipant(conversationId) {
      return signedIn()
        && exists(/databases/$(database)/documents/conversations/$(conversationId))
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
    }

    function hasValidConversationParticipants() {
      return signedIn()
        && request.resource.data.participants is list
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() >= 2
        && request.resource.data.participants.size() <= 50;
    }

    // Unique handles: public read; create/delete when the authenticated user matches { uid }.
    match /usernames/{uname} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid'])
        && request.auth.uid == request.resource.data.uid;
      allow update: if false;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.uid;
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    match /clips/{clipId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource != null
        && resource.data.userId == request.auth.uid;
    }

    // Clip subcollections (likes, comments, …). Emoji reactions path removed from UI — block writes under reactions/*.
    match /clips/{clipId}/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && !document.matches("reactions/.*");
    }

    match /savedClips/{id} {
      allow read, delete: if ownsSavedClip();
      allow create: if createsOwnSavedClip();
      allow update: if ownsSavedClip()
        && request.resource.data.userId == resource.data.userId;
    }

    match /follows/{id} {
      allow read, write: if request.auth != null;
    }

    match /conversations/{id} {
      allow read, delete: if signedIn()
        && request.auth.uid in resource.data.participants;
      allow create: if hasValidConversationParticipants();
      allow update: if signedIn()
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants;
    }

    match /conversations/{id}/messages/{mid} {
      allow read: if isConversationParticipant(id);
      allow create: if isConversationParticipant(id)
        && request.resource.data.senderId == request.auth.uid;
      allow update: if isConversationParticipant(id)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isConversationParticipant(id);
    }
  }
}
