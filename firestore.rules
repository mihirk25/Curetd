rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isConversationParticipant(id) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/conversations/$(id))
        && request.auth.uid in get(/databases/$(database)/documents/conversations/$(id)).data.participants;
    }

    function createsConversationForSelf() {
      return isSignedIn()
        && request.resource.data.participants is list
        && request.resource.data.participants.size() >= 2
        && request.resource.data.participants.size() <= 50
        && request.auth.uid in request.resource.data.participants;
    }

    // Unique handles: public read; create/delete when the authenticated user matches { uid }.
    match /usernames/{uname} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly(['uid'])
        && request.auth.uid == request.resource.data.uid;
      allow update: if false;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.uid;
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    match /clips/{clipId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource != null
        && resource.data.userId == request.auth.uid;
    }

    // Clip subcollections (likes, comments, …). Emoji reactions path removed from UI — block writes under reactions/*.
    match /clips/{clipId}/{document=**} {
      allow read: if true;
      allow write: if request.auth != null && !document.matches("reactions/.*");
    }

    match /savedClips/{id} {
      allow read, write: if request.auth != null;
    }

    match /follows/{id} {
      allow read, write: if request.auth != null;
    }

    match /conversations/{id} {
      allow create: if createsConversationForSelf();
      allow get, list: if isSignedIn()
        && request.auth.uid in resource.data.participants;
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'lastMessage',
          'lastMessageAt',
          'unreadBy',
        ]);
      // Parent deletes orphan the message subcollection and remove the thread for every participant.
      allow delete: if false;
    }

    match /conversations/{id}/messages/{mid} {
      allow get, list: if isConversationParticipant(id);
      allow create: if isConversationParticipant(id)
        && request.resource.data.senderId == request.auth.uid;
      allow update: if isConversationParticipant(id)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
        && request.resource.data.read is bool;
      allow delete: if isConversationParticipant(id)
        && resource.data.senderId == request.auth.uid;
    }
  }
}
