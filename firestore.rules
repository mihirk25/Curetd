rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isClipOwner(clipId) {
      return signedIn()
        && get(/databases/$(database)/documents/clips/$(clipId)).data.userId == request.auth.uid;
    }

    function isConversationParticipant(data) {
      return signedIn()
        && data.participants is list
        && request.auth.uid in data.participants;
    }

    function isConversationParticipantById(id) {
      return isConversationParticipant(
        get(/databases/$(database)/documents/conversations/$(id)).data
      );
    }

    // Unique handles: public read; create/delete when the authenticated user matches { uid }.
    match /usernames/{uname} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.keys().hasOnly(['uid'])
        && request.auth.uid == request.resource.data.uid;
      allow update: if false;
      allow delete: if signedIn()
        && request.auth.uid == resource.data.uid;
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    match /clips/{clipId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn()
        && resource != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;
      allow delete: if signedIn()
        && resource != null
        && resource.data.userId == request.auth.uid;
    }

    match /clips/{clipId}/likes/{userId} {
      allow read: if true;
      allow create, update, delete: if isOwner(userId);
    }

    match /clips/{clipId}/comments/{commentId} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if false;
      allow delete: if signedIn()
        && (resource.data.userId == request.auth.uid || isClipOwner(clipId));
    }

    // Emoji reactions path removed from UI — keep writes blocked.
    match /clips/{clipId}/reactions/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /savedClips/{id} {
      allow read: if signedIn()
        && resource.data.userId == request.auth.uid;
      allow create, update: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if signedIn()
        && resource.data.userId == request.auth.uid;
    }

    match /follows/{id} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.followerId == request.auth.uid
        && request.resource.data.followingId is string
        && request.resource.data.followingId != request.auth.uid;
      allow delete: if signedIn()
        && resource.data.followerId == request.auth.uid;
    }

    match /collections/{id} {
      allow read: if true;
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId;
      allow delete: if signedIn()
        && resource.data.userId == request.auth.uid;
    }

    match /topics/{id} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.resource.data.keys().hasOnly(['name', 'count', 'createdAt', 'createdBy']);
      allow delete: if false;
    }

    match /reposts/{id} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.resource.data.repostedByUid == request.auth.uid;
      allow delete: if signedIn()
        && resource.data.repostedByUid == request.auth.uid;
    }

    match /conversations/{id} {
      allow read: if isConversationParticipant(resource.data);
      allow create: if isConversationParticipant(request.resource.data);
      allow update: if isConversationParticipant(resource.data)
        && request.resource.data.participants == resource.data.participants;
      allow delete: if isConversationParticipant(resource.data);
    }

    match /conversations/{id}/messages/{mid} {
      allow read: if isConversationParticipantById(id);
      allow create: if isConversationParticipantById(id)
        && request.resource.data.senderId == request.auth.uid;
      allow update: if isConversationParticipantById(id)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])
        && request.resource.data.read == true;
      allow delete: if isConversationParticipantById(id)
        && resource.data.senderId == request.auth.uid;
    }
  }
}
